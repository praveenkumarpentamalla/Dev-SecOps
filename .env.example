# =============================================================================
# .env.example — commit this file, never .env
# Copy to .env and fill in real values:  cp .env.example .env
# =============================================================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_SECRET_KEY=change-me-to-a-random-32-char-string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=change-me

# AWS (use OIDC in CI/CD — these are for local dev only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h

# Third-party APIs
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key-here
SENDGRID_API_KEY=SG.your-sendgrid-key-here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Redis
REDIS_URL=redis://localhost:6379
